# Campaign Operations OS - Environment Configuration
# ================================================
#
# Copy this file to .env and update ALL placeholder values.
#
# SECURITY WARNING:
# - Never commit .env to version control
# - Replace all <PLACEHOLDER> values before running
# - Use strong, unique secrets in production
#
# For Docker development:
#   cp .env.example .env
#   # Edit .env and set your secrets
#   docker-compose up

# =============================================================================
# Application
# =============================================================================
APP_NAME="Campaign Operations OS"
APP_VERSION="0.1.0"

# Environment: development | staging | production
# - development: Allows insecure defaults, shows debug info
# - staging/production: Requires all secrets, fails on insecure values
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=true

# =============================================================================
# API Configuration
# =============================================================================
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Database (REQUIRED)
# =============================================================================
# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local development:
DATABASE_URL=postgresql://campaign_os:campaign_os@localhost:5432/campaign_os
#
# Docker (overridden by docker-compose.yml):
# DATABASE_URL=postgresql://campaign_os:campaign_os@postgres:5432/campaign_os
#
# Production example (use secrets manager):
# DATABASE_URL=postgresql://app_user:<STRONG_PASSWORD>@db.example.com:5432/campaign_os

# =============================================================================
# Redis (REQUIRED)
# =============================================================================
# Redis connection URL for caching and token blacklist
#
# Local development:
REDIS_URL=redis://localhost:6379/0
#
# Production with password:
# REDIS_URL=redis://:<REDIS_PASSWORD>@redis.example.com:6379/0

# =============================================================================
# JWT Authentication (REQUIRED - CHANGE IN PRODUCTION!)
# =============================================================================
# Secret key for signing JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# SECURITY: Must be at least 32 characters, unique per environment
JWT_SECRET_KEY=<GENERATE_A_SECURE_32_CHAR_SECRET>

# Token expiration settings
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Password Hashing
# =============================================================================
# Bcrypt work factor (12 is good balance of security/speed)
PASSWORD_HASH_ROUNDS=12

# =============================================================================
# S3/MinIO Storage (Optional - required if using file uploads)
# =============================================================================
# MinIO endpoint for local development
S3_ENDPOINT=http://localhost:9000

# S3/MinIO credentials
# For local MinIO development:
S3_ACCESS_KEY=<MINIO_ACCESS_KEY>
S3_SECRET_KEY=<MINIO_SECRET_KEY>
#
# For AWS S3 production:
# S3_ACCESS_KEY=<AWS_ACCESS_KEY_ID>
# S3_SECRET_KEY=<AWS_SECRET_ACCESS_KEY>

S3_BUCKET_NAME=campaign-os
S3_REGION=us-east-1
S3_USE_SSL=false

# =============================================================================
# File Uploads
# =============================================================================
MAX_UPLOAD_SIZE_MB=50

# =============================================================================
# Email Configuration (Optional)
# =============================================================================
# SMTP settings for sending emails (password reset, notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@campaign-os.local
SMTP_FROM_NAME=Campaign OS

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Google OAuth (Optional - for Google Calendar integration)
# =============================================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Encryption key for storing OAuth tokens securely
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED if Google OAuth is enabled
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# URLs for OAuth Redirects
# =============================================================================
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
